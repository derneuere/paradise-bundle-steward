{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "_comment": "Scoped to streetData only. Tests may reach into other core modules; we mutate just streetData.ts to keep the run fast and survivors actionable.",
  "packageManager": "npm",
  "testRunner": "vitest",
  "vitest": {
    "configFile": "vite.config.ts"
  },
  "reporters": ["html", "json", "clear-text", "progress"],
  "htmlReporter": {
    "fileName": "reports/mutation/streetData.html"
  },
  "jsonReporter": {
    "fileName": "reports/mutation/streetData.json"
  },
  "mutate": [
    "src/lib/core/streetData.ts",
    "src/lib/core/collisionTag.ts"
  ],
  "incremental": true,
  "incrementalFile": "reports/mutation/.stryker-incremental.json",
  "coverageAnalysis": "perTest",
  "timeoutMS": 15000,
  "concurrency": 4,
  "thresholds": { "high": 80, "low": 60, "break": null }
}
